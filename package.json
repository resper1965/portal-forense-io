{
  "name": "forense-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev dist",
    "deploy": "wrangler pages deploy dist",
    "db:migrate": "wrangler d1 execute forense-db --file=migrations/0001_initial.sql",
